{
  "manifest_version": 3,
  "name": "World Clock Side Panel",
  "version": "1.0.0",
  "description": "A pinnable side-panel world clock with multiple timezones, dark/light themes, and persistent settings.",
  "permissions": ["sidePanel", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open World Clock",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
